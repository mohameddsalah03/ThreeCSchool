{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "http://localhost:5173",
    "http://localhost:3000",
    "https://3cschool.net"
  ],
  "ConnectionStrings": {
    "MainContext": "Server=.;Database=ThreeCSchool.Main;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "JwtSettings": {
    "Key": "your-super-secret-key-min-256-bit-length!",
    "Issuer": "ThreeCSchoolIdentity",
    "Audience": "ThreeCSchoolUsers",
    "DurationInMinutes": 15,
    "RefreshTokenDurationInDays": 7
  },
  "EmailSettings": {
    "From": "no-reply@3cschool.net",
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "UserName": "your-email@gmail.com",
    "Password": "your-app-password"
  },
  "AppSettings": {
    "FrontendUrl": "http://localhost:5173",
    "AdminEmail": "admin@3cschool.net"
  }
}